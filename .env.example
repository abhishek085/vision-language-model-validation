# Copy to .env and tweak as needed. The server auto-loads .env on startup.

# Device for local inference. Leave unset to auto-detect:
#   mps  -> Apple Silicon GPU (default on M-series Macs)
#   cpu  -> slow fallback (use if mps runs out of memory)
#   cuda -> NVIDIA GPU
# TORCH_DEVICE=mps

# Cap generated tokens for lift (lower = less memory / faster).
# MAX_OUTPUT_TOKENS=2048

# Override the lift checkpoint if you have a local/quantized copy.
# MODEL_CHECKPOINT=datalab-to/lift

# Web server port.
# PORT=8000

# Where HuggingFace caches downloaded weights.
# HF_HOME=~/.cache/huggingface
